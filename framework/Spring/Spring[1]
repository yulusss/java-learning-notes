###### OrderService类

```java
package com.felix.springStudy.service;

import com.felix.springStudy.dao.OrderDAO;

/**
 * @author 云禄
 * @version 1.0
 */

public class OrderService {
    private OrderDAO orderDAO;

    public OrderDAO getOrderDAO() {
        return orderDAO;
    }

    public void setOrderDAO(OrderDAO orderDAO) {
