## 实现简单基于XML配置程序

###### 写一个简单的Spring答器，通过读取beans.xml，获取第1个JavaBean:Monster的对象，并给该对象属性赋值，放入到容器中，输出该对象信息.

![截屏2026-04-05 21.16.14](assets/截屏2026-04-05 21.16.14.png)

```java
package com.felix.springStudy.felixApplicationContext;

import com.felix.springStudy.bean.Monster;
import org.dom4j.Document;
import org.dom4j.Element;
import org.dom4j.io.SAXReader;

import java.io.File;
import java.lang.reflect.Constructor;
import java.util.List;
import java.util.Objects;
import java.util.concurrent.ConcurrentHashMap;

/**
 * @author 云禄
 * @version 1.0
 * 用于实现 Spring 的一个简单容器机制
 * 将 beans.xml 文件解析，并生成对象，放入容器中
 * 提供方法返回对象 getBean(id)
 */

public class FelixApplicationContext {

    private ConcurrentHashMap<String, Object> singletonObjects = new ConcurrentHashMap<>();

    //构造器
    //接收一个容器的配置文件,比如 beans.xml,该文件必须在 resource 下
    public FelixApplicationContext(String iocBeanXmlFile) throws Exception {
        //得到类加载路径
        String path = Objects.requireNonNull(this.getClass().getResource("/")).getPath();
        //创建 SAXReader
        SAXReader saxReader = new SAXReader();
        //得到 Document 对象
        //类加载路径拼接配置文件，做到绝对路径
        Document document = saxReader.read(new File(path + iocBeanXmlFile));
        //得到根元素
        Element rootElement = document.getRootElement();
        //得到第一个 bean
        Element bean = (Element) rootElement.elements("bean").get(0);
        //得到第一个 bean 的相关属性
        String beanId = bean.attributeValue("id");
        String classFullPath = bean.attributeValue("class");

        //获取所有属性
        List<Element> elements = bean.elements("property");
        ///直接获取
        Integer id = Integer.parseInt(elements.get(0).attributeValue("value"));
        String name = elements.get(1).attributeValue("value");
        String skill = elements.get(2).attributeValue("value");

        //使用反射创建对象
        Class<?> aClass = Class.forName(classFullPath);
        Constructor<?> constructor = aClass.getConstructor();
        //这里的 o 已经是 Monster 类的，因为没有赋值，所以是默认的，也可以直接进行强转
        //Object o = constructor.newInstance();
        Monster o = (Monster) constructor.newInstance();
        //这里应该使用反射机制来赋值
        //为了简化，暂时使用硬编码
        o.setId(id);
        o.setName(name);
        o.setSkill(skill);

        //将创建好的对象放入到 singletonObjects 池中
        singletonObjects.put(beanId , o);
    }

    //返回对象的方法
    public Object getBean(String id){
        Object o = singletonObjects.get(id);
        if(o == null){
            return null;
        }
        return o;
    }
}
```

