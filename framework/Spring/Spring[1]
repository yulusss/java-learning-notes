## 通过FactoryBean获取Bean[重点]

###### 在Spring的ioc容器，可以通过 FactoryBean 获取 Bean

#### FactoryBean类

```java
package com.felix.springStudy.factory;

import com.felix.springStudy.bean.Monster;
import org.jspecify.annotations.Nullable;
import org.springframework.beans.factory.FactoryBean;

import java.util.HashMap;
import java.util.Map;

/**
 * @author 云禄
 * @version 1.0
 */

public class MyFactoryBean implements FactoryBean<Monster> {

    //这个是配置时，指定要获取的对象的对应的key
    private String key;

    private Map<String , Monster> monster_map;

    //代码块初始化
    {
        monster_map = new HashMap<>();
        monster_map.put("monster03", new Monster(100, "牛魔王_", "芭蕉扇_"));
        monster_map.put("monster04", new Monster(200, "孙悟空_", "七十二变_"));
    }

    public void setKey(String key) {
        this.key = key;
    }

    //指定要返回的 FactoryBean 中的对象
    @Override
    public @Nullable Monster getObject() throws Exception {
        return monster_map.get(key);
    }

    //返回的类型
    @Override
    public @Nullable Class<?> getObjectType() {
        return Monster.class;
    }

    //返回的对象是不是单例
    @Override
    public boolean isSingleton() {
        return true;
    }
}
```

#### 配置文件

```xml
<!--配置 Monster 对象，通过 FactoryBean 获取-->
<!--
1.class 指定要使用的 FactoryBean
2.key 表示 MyFactoryBean 中的属性 key
3.value 就是要获取的对象的对象的 key
-->
<bean id="my_monster04" class="com.felix.springStudy.factory.MyFactoryBean">
    <property name="key" value="monster04"/>
</bean>
```

