#### FelixFilterConfig.java

```java
package com.felix.filter;
import jakarta.servlet.*;
import java.io.IOException;
import java.util.Enumeration;

/**
 * @author 云禄
 * @version 1.0
 */
public class FelixFilterConfig implements Filter {
    @Override
    public void init(FilterConfig filterConfig) throws ServletException {
        //通过 filterConfig 获取获取相关的参数

        //配置 filter 时的名字，即 web.xml 中的 <filter-name> --> FelixFilterConfig
        String filterName = filterConfig.getFilterName();

        //配置 Filter 时的一些参数，像是 Web.xml 文件中的 ip , port
        String ip = filterConfig.getInitParameter("ip");

        //典型用途：
        //1.网站总访问量统计
        //2.在线用户列表
        //3.全局配置信息
        ServletContext servletContext = filterConfig.getServletContext();
        //也就说可以实现存储全局数据（所有用户都能访问）
        servletContext.setAttribute("company" , "FelixCompany");
        //也能获取全局数据
        Object address = servletContext.getAttribute("address");

        //获取 Filter 所有的配置参数名称
        //这里对应着 web.xml 文件中的 ip 和 port
        Enumeration<String> initParameterNames = filterConfig.getInitParameterNames();
        //Enumeration 是一个古老的遍历接口，用法类似迭代器：
        /*
        常用方法：
            方法                  作用
            hasMoreElements()   判断是否还有下一个元素（类似 hasNext()）
            nextElement()       返回下一个元素（类似 next()）
         */
        // 判断是否还有下一个元素
        while (initParameterNames.hasMoreElements()) {
            // 获取下一个元素
            String name = initParameterNames.nextElement();
            // 根据名字获取值
            String value = filterConfig.getInitParameter(name);
            System.out.println(name + "=" + value);
        }
    }

    @Override
    public void doFilter(ServletRequest servletRequest, ServletResponse servletResponse, FilterChain filterChain) throws IOException, ServletException {

    }

    @Override
    public void destroy() {
        Filter.super.destroy();
    }
}
```

