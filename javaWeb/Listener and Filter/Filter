###### ManagerFilter.java

```java
package com.felix.filter;

import jakarta.servlet.*;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpSession;

import java.io.IOException;

/**
 * @author 云禄
 * @version 1.0
 */

//这里实现的 Filter 一定要是 Jakarta.servlet 里的
public class ManagerFilter implements Filter {

    /*
    可以理解 tomcat 还维护了 filter 的容器
        public static final ConcurrentHashMap<String, String>
            filterUrlMapping = new ConcurrentHashMap<>() ;

        public static final ConcurrentHashMap<String, Filter>
            filterMapping = new ConcurrentHashMap<> ();

    可以理解在调用 servlet 之前，先匹配 filter
        1. 根据 request 对象封装的uri
        2. 到 filterUrlMapping 去匹配
        3. 如果匹配上就调用 filterMapping 对应的 filer 对象 doFilter()
        4. 如果没有匹配上，就直接走后面的 servlet/jsp/htmL.
     */

    @Override
    public void doFilter(ServletRequest servletRequest, ServletResponse servletResponse, FilterChain filterChain) throws IOException, ServletException {
        //当每次调用 Filter 时 就会调用该 doFilter()
        System.out.println("ManagerFilter doFilter()被调用...");

        HttpServletRequest httpServletRequest = (HttpServletRequest) servletRequest;
        HttpSession session = httpServletRequest.getSession();
        Object username = session.getAttribute("username");

        if(username == null){
            //如果 Session 中没有 username 的 value ，说明是直接访问这个页面，则返回到 login.jsp
            //如果这里没有调用继续请求的方法，就停止,并返回 login.jsp
            servletRequest
                    .getRequestDispatcher("/login.jsp")
                    .forward(servletRequest , servletResponse);

        }else {

            //说明已经登录过了，放行
            //在调用过滤器前，servletRequest --> request 对象已经被创建并封装
            //所以这里就可以通过 servletRequest 获取信息，比如 url，session，访问的参数数据
            //就可以做事务管理，数据获取，日志管理等
            filterChain.doFilter(servletRequest, servletResponse);
            //这里的 filterChain.doFilter() 是指继续访问目标资源
            //servletRequest 和 servletResponse 对象会传递给目标资源/文件
            //filter 传递的两个对象，在后面的 servLet/jsp 是同一个对象(指的是在一次 http 请求中)
            //也就是说 /manager/* 访问的 servLet/jsp 都是这两个对象
        }
    }

    @Override
    public void init(FilterConfig filterConfig) throws ServletException {
        //当 Tomcat 创建 Filter 后，就会调用该方法，进行初始化
        System.out.println("ManagerFilter init() 被调用...");
    }

    @Override
    public void destroy() {
        //当 Filter 被销毁时，调用此方法
        System.out.println("ManagerFilter destroy() 被调用...");
    }
}
```

