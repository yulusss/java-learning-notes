HttpSessionListener监听器

```java
package com.felix.listener;

import jakarta.servlet.http.HttpSession;
import jakarta.servlet.http.HttpSessionEvent;
import jakarta.servlet.http.HttpSessionListener;

/**
 * @author 云禄
 * @version 1.0
 */

public class FelixHttpSessionListener implements HttpSessionListener {
    @Override
    public void sessionCreated(HttpSessionEvent se) {
        HttpSession session = se.getSession();
        //当 session 被创建时，设置生命周期
        //15秒 后自动销毁
        session.setMaxInactiveInterval(15);
        System.out.println("FelixHttpSessionListener 监听到 Session: "  + session +
                " 创建,id = " + session.getId());
        System.out.println("用户: " + session.getId() + "上线了");
    }

    @Override
    public void sessionDestroyed(HttpSessionEvent se) {
        HttpSession session = se.getSession();
        System.out.println("FelixHttpSessionListener 监听到 Session: "  + session +
                " 销毁,id = " + session.getId());
        System.out.println("用户: " + session.getId() + "离线了");
    }
}
```

