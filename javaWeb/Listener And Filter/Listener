## ServletContextAttributeListener监听器

1. ###### 作用：监听ServletContext属性变化

2. ###### 方法

```java
void attributeAdded（ServletContextAttributeEvent event） //添加属性时调用
void attributeReplaced（ServletContextAttributeEvent event） //替换属性时调用
void attributeRemoved（ServletContextAttributeEvent event） //移除属性时调用
```

3. ###### 这个监听器使用相对较少

Servlet

```java
package com.felix.servlet;

import jakarta.servlet.ServletContext;
import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

import java.io.IOException;
import java.io.PrintWriter;

/**
 * @author 云禄
 * @version 1.0
 */

@WebServlet(name = "HisServlet" , urlPatterns = "/hiServlet")
public class HiServlet extends HttpServlet {
    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        //给 servletContext 对象操作属性
        ServletContext servletContext = req.getServletContext();
        //添加
        servletContext.setAttribute("name" , "Felix");
        //修改
        servletContext.setAttribute("name" , "Yules");
        //删除
        servletContext.removeAttribute("name");

        resp.setContentType("text/html;charset=utf-8");
        PrintWriter writer = resp.getWriter();
        writer.println("<h1>HiServlet 操作结束</h1>");
        writer.flush();
        writer.close();
    }

    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        doPost(req , resp);
    }
}
```

ServletContextAttributeListener监听器

```java
package com.felix.listener;

import jakarta.servlet.ServletContextAttributeEvent;
import jakarta.servlet.ServletContextAttributeListener;

/**
 * @author 云禄
 * @version 1.0
 */

public class FelixServletContextAttributeListener implements ServletContextAttributeListener {
    @Override
    public void attributeAdded(ServletContextAttributeEvent event) {
        String name = event.getName();
        Object value = event.getValue();
        System.out.println("FelixServletContextAttributeListener监听到添加属性 " + name +
                " = " + value);
    }

    @Override
    public void attributeRemoved(ServletContextAttributeEvent event) {
        String name = event.getName();
        Object value = event.getValue();
        System.out.println("FelixServletContextAttributeListener监听到删除属性 " + name +
                " = " + value);
    }

    @Override
    public void attributeReplaced(ServletContextAttributeEvent event) {
        String name = event.getName();
        Object value = event.getValue();
        //输出的是修改前的信息
        System.out.println("FelixServletContextAttributeListener监听到修改属性 " + name +
                " = " + value);
    }
}
```

