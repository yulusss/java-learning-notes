## Cookie有效路径

Cookie中的Path属性可以有效的控制哪些cookie可以发送给浏览器，哪些不可以

规则如下

```
cookie1.setPath = /工程路径
cookie2.setPath = /工程路径/aaa

请求地址：http://ip:端口/工程路径/资源
cookie1会发送给浏览器
cookie2不会发送给浏览器

请求地址：http://ip:端口/工程路径/aaa/资源
cookie1会发送给浏览器
cookie2会发送给浏览器
```

```java
/**
 * @author 云禄
 * @version 1.0
 */

public class CookiePath extends HttpServlet {
    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        //1.创建两个 Cookie
        Cookie cookie = new Cookie("address" , "Beijing");
        Cookie cookie1 = new Cookie("salary", "8k");

        //2.设置不同的有效路径

        //req.getContextPath() 获取Tomcat的工程路径，例如 /servlet
        cookie.setPath(req.getContextPath());
        //req.getContextPath() + "/aaa" -> /servlet/aaa
        cookie1.setPath(req.getContextPath() + "/aaa");

        //3.保存到浏览器
        resp.addCookie(cookie);
        resp.addCookie(cookie1);
    }

    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        doPost(req , resp);
    }
}
```

## Cookie实例

给定username为Felix，pasword为129103，若登录成功则记住密码，生命周期3天，以后每次访问登录页面都自动填写username和password，若登录失败，则提示

这里不能使用html静态页面，因为涉及自动填写，静态页面无法满足，需要使用servlet

### UserUIServlet：

```java
/**
 * @author 云禄
 * @version 1.0
 */

public class UserUIServlet extends HttpServlet {
  @Override
  protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {

    //读取从浏览器发送来的 Cookie 信息
    Cookie[] cookies = req.getCookies();
    Cookie usernameCookie = CookieUtils.readCookieByName("username", cookies);
    Cookie passwordCookie = CookieUtils.readCookieByName("password", cookies);

    //涉及se中的作用域，必须在外面定义
    String username = "";
    String password = "";

    if(usernameCookie != null && passwordCookie != null){
      username = usernameCookie.getValue();
      password = passwordCookie.getValue();
    }

    resp.setContentType("text/html;charset=utf-8");
    //1.得到 writer
    //得到动态页面
    PrintWriter writer = resp.getWriter();
    writer.println("<!DOCTYPE html>\n" +
                   "<html lang=\"en\">\n" +
                   "<head>\n" +
                   "    <meta charset=\"UTF-8\">\n" +
                   "    <title>登录</title>\n" +
                   "</head>\n" +
                   "<body>\n" +
                   "<h1>登录用户</h1>\n" +
                   "<form action=\"/cookie/homework01\" method=\"post\">\n" +
                   "    username: <input type=\"text\" value=\"" + username + "\"name=\"username\"><br/><br/>\n" +
                   "    password: <input type=\"password\" value=\"" + password + "\"name=\"password\"><br/><br/>\n" +
                   "    <input type=\"submit\" value=\"提交\">\n" +
                   "</form>\n" +
                   "</body>\n" +
                   "</html>");
    writer.flush();
    writer.close();


  }

  @Override
  protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
    doPost(req , resp);
  }
}
```

### 检验端

```java
/**
 * @author 云禄
 * @version 1.0
 */

public class Homework01 extends HttpServlet {
    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {


        PrintWriter writer = resp.getWriter();
        resp.setContentType("text/html;charset=utf-8");


        //接收表单提交数据
        String username = req.getParameter("username");
        String password = req.getParameter("password");


        //判断是否合法
        if(username.equals("Felix") && password.equals("129103")){

            //当没有Cookie信息时，创建Cookie
            //当有信息时，不要重复创建，直接输出登录成功
            Cookie[] cookies = req.getCookies();
            Cookie usernameCookie = CookieUtils.readCookieByName("username", cookies);
            Cookie passwordCookie = CookieUtils.readCookieByName("password", cookies);
            if(usernameCookie == null && passwordCookie == null){
                //利用 Cookie 将数据保存到浏览器中，生命周期为3天
                Cookie cookie = new Cookie("username", "Felix");
                cookie.setMaxAge(60 * 60 * 24 * 3);
                Cookie cookie1 = new Cookie("password", "129103");
                cookie1.setMaxAge(60 * 60 * 24 * 3 );

                resp.addCookie(cookie);
                resp.addCookie(cookie1);
            }

            writer.println("<h1>登录成功</h1>");
        }else{
            writer.println("<h1>登录失败</h1>");
        }
        writer.flush();
        writer.close();
    }

    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        doPost(req , resp);
    }
}

