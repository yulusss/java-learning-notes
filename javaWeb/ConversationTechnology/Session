##### 检查数据

```java
/**
 * @author 云禄
 * @version 1.0
 */

public class LoginCheckServlet extends HttpServlet {

    private static final String CORRECT_PASSWORD = "666666";

    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp)
            throws ServletException, IOException {

        String username = req.getParameter("username");
        String password = req.getParameter("password");

        // 输入验证
        if (username == null || username.trim().isEmpty()) {
            // 用户名空，返回登录页并提示
            resp.setContentType("text/html;charset=utf-8");
            PrintWriter writer = resp.getWriter();
            writer.println("<script>");
            writer.println("alert('用户名不能为空');");
            writer.println("history.back();"); // 返回上一页
            writer.println("</script>");
            writer.close();
            return;
        }

        // 密码验证
        if (CORRECT_PASSWORD.equals(password)) {
            // 登录成功，创建Session
            HttpSession session = req.getSession();
            session.setAttribute("user", username);

            // 重定向到管理页面
            resp.sendRedirect(req.getContextPath() + "/manager");
        } else {
            // 登录失败，重定向到错误页面
            resp.sendRedirect(req.getContextPath() + "/err.html");
        }
    }

    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp)
            throws ServletException, IOException {
        doPost(req, resp);
    }
}
```

##### 登录成功页面

```java
/**
 * @author 云禄
 * @version 1.0
 */

public class ManagerService extends HttpServlet {
    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        HttpSession session = req.getSession();
        resp.setContentType("text/html;charset=utf-8");
        PrintWriter writer = resp.getWriter();
        Object user = session.getAttribute("user");
        if(user != null){
            writer.println("<h2>欢迎管理员" + (String)user + "</h2>");
        }else{
            resp.sendRedirect(req.getContextPath() + "/login.html");
        }
        writer.flush();
        writer.close();
    }

    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        doPost(req , resp);
    }
}
```

