## choose标签

```jsp
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%--
  Created by IntelliJ IDEA.
  User: a728910
  Date: 2026/3/29
  Time: 15:09
  To change this template use File | Settings | File Templates.
--%>
<%@ page contentType="text/html;charset=UTF-8" language="java" isELIgnored="false" %>
<html>
<head>
    <title>Title</title>
</head>
<body>
<c:set scope="request" var="score" value="70"/>
<c:choose>
<%--    1. 如果＄｛requestScope.score｝那么就明确的指定从request域对象取出数据--%>
<%--    2．如果$｛score｝，就按照从小到大的域范围去获取--%>
    <c:when test="${requestScope.score > 80}">
        <h1>优秀</h1></c:when>
    <c:when test="${requestScope.score < 80 && requestScope.score > 60}">
        <h1>及格</h1></c:when>
    <c:when test="${requestScope.score <= 60}">
        <h1>不及格</h1></c:when>
</c:choose>
</body>
</html>
```

