<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<html>
<head>
    <title>简易计算器</title>
    <script type="text/javascript">
        function check(){
            //得到num1,num2
            var num1 = document.getElementById("num1").value;
            var num2 = document.getElementById("num2").value;
            var symbol = document.getElementById("symbol").value;

            var allIntegerRegex = /^-?(0|[1-9]\d*)$/;
            if(!allIntegerRegex.test(num1)){
                alert("num1不是一个整数");
                return false;
            }else if(!allIntegerRegex.test(num2)){
                alert("num2不是一个整数");
                return false;
            }else if(symbol === 'division' && parseInt(num2) === 0){
                alert("除数不能为0");
                return false;
            }
            return true;
        }
    </script>
</head>
<body>
<h1>简易计算器</h1>
<form method="post" action="<%=request.getContextPath()%>/calServlet" onsubmit="return check()">
    num1: <input type="text" id="num1" name="num1"><br/>
    num2: <input type="text" id="num2" name="num2"><br/>
    运算符号: <select name="symbol" id="symbol">
    <option value="add">+</option>
    <option value="reduce">-</option>
    <option value="multiple">*</option>
    <option value="division">/</option>
</select>
    <input type="submit" value="计算">
</form>
</body>
</html>
```

#### Servlet

```java
package com.felix.bean;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

import java.io.IOException;

/**
 * @author 云禄
 * @version 1.0
 */
public class CalServlet extends HttpServlet {
    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        doPost(req , resp);
    }

    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        String strNum1 = req.getParameter("num1");
        int num1 = Integer.parseInt(strNum1);
        String strNum2 = req.getParameter("num2");
        int num2 = Integer.parseInt(strNum2);
        String symbol = req.getParameter("symbol");
        String sym = "";
        int result = 0;
        if(symbol.equals("add")){
            sym = "+";
            result = num1 + num2;
        }else if(symbol.equals("reduce")){
            sym = "-";
            result = num1 - num2;
        }else if(symbol.equals("multiple")){
            sym = "*";
            result = num1 * num2;
        }else if(symbol.equals("division")){
            sym = "/";
            result = num1 / num2;
        }


        String format = String.format("%s %s %s = %s", num1, sym , num2 , result);
        req.setAttribute("res" , format);
        req.getRequestDispatcher("/cal/calRes.jsp").forward(req , resp);
    }
}
```

