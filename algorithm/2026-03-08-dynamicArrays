    //简化后
    public void add(int index /* 插入的索引位置 */, int element) {
        //判断 index 是否合理
        if(index < 0 || index > size){
            throw new ArrayIndexOutOfBoundsException("索引越界");
        }

        checkAndGrow();//检查元素是否需要扩容

        //如果索引不是最后一个，将原数组 index 之后的值向后移动一位，为新元素空出位置添加
        if (index >= 0 && index < size) {
            System.arraycopy(array, index, array, index + 1, size - index);
//            array[index] = element;
//            size++;
//        } else if (index == size) {
//            array[size] = element;
//            size++;
        }
        array[index] = element;
        size++;
    }

    //添加元素到最后一个位置
    public void addLast(int element){
        checkAndGrow();//检查元素是否需要扩容
        add(size , element);
    }


    //返回索引处的值
    public int get(int index){
        //判断 index 是否合理
        if(index < 0 || index > size - 1){
            throw new ArrayIndexOutOfBoundsException("索引越界");
        }
        return array[index];
    }

    //数组遍历
    //方式1:使用Consumer接口
    public void myForEach(Consumer<Integer> consumer){
        for (int i = 0; i < size; i++) {
            consumer.accept(array[i]);
        }
    }
