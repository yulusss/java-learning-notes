import java.util.Iterator;

public class DoubleLinkedList implements Iterable<Integer>{
    //节点类
    static class Node{
        Node prev;//上一个节点指针
        int value;//值
        Node next;//下一个节点指针

        public Node(Node prev, int value, Node next) {
            this.prev = prev;
            this.value = value;
            this.next = next;
        }
    }

    private Node head;//头哨兵
    private Node tail;//尾哨兵

    public DoubleLinkedList() {
        //初始化头尾哨兵，使其互相指定
        head = new Node(null , 0 , null);
        tail = new Node(null , 0 , null);
        head.next = tail;
        tail.prev = head;
    }

    //根据索引位置找到节点对象
    private Node findNode(int index){
        int i = -1;//从 -1 开始查找，也就是从头哨兵开始查找
        //从 head 开始 ， 当 pointer 指向 为哨兵时停止遍历
        for(Node pointer = head ; pointer != tail ; pointer = pointer.next , i++){
            if(i == index){
                return pointer;
            }
        }
        return null;
    }

    //根据索引值，插入新节点
    public void insert(int index , int value){
        Node prev = findNode(index - 1);//前一个节点
        if(prev == null){
            throw new IllegalArgumentException("索引无效");
        }
        Node next = prev.next;//原节点（新节点要插在它前面）
        //此处 next 如果为 null 是正常的，因为 prev 后面就是 tail，没有下一个有效节点
        Node node = new Node(prev, value, next);
        prev.next = node;
        next.prev = node;
    }

    //删除指定索引位置的节点
    public void remove(int index){
        // 找到要删除的节点
        Node removed = findNode(index);
        if (removed == null || removed == tail) {
            throw new IllegalArgumentException("索引无效");
        }

        // 前后节点
        Node prev = removed.prev;
        Node next = removed.next;

        // 跳过 removed
        prev.next = next;
        next.prev = prev;
    }

    //添加节点到最后
    public void addLast(int value){
        Node last = tail.prev;//除哨兵节点外最后一个节点
        Node node = new Node(last, value, tail);//前指针指向最后一个节点，后指针指向尾哨兵节点
        last.next = node;//最后一个节点后指针指向新节点
        tail.prev = node;//尾哨兵节点前指针指向新节点
    }

    //删除最后一个节点
    public void remove(){
        Node removed = tail.prev;//要被删除的节点
        if(head == removed){
            throw new IllegalArgumentException("链表为空");
        }
        Node prev = removed.prev;
        prev.next = tail;
        tail.prev = prev;
    }

    //Iterable 迭代器遍历
    @Override
    public Iterator<Integer> iterator() {
        return new Iterator<Integer>() {
            Node pointer = head.next;//从头哨兵之后开始遍历
            @Override
            public boolean hasNext() {
                return pointer != tail;
            }

            @Override
            public Integer next() {
                int value = pointer.value;
                pointer = pointer.next;
                return value;
            }
        };
    }
}
