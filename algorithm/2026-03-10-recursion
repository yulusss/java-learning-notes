    //递归类
    //某个节点要进行的操作
    private void recursion(Node curr/* 当前要处理的节点*/ , Consumer<Integer> before , Consumer<Integer> after){
        //等于 null 时结束递归
        if(curr == null){
            return;
        }

        before.accept(curr.value);//正序
        recursion(curr.next , before , after);
        after.accept(curr.value);//倒序
    }

    //反向打印字符串
    public class ReversePrintString {

    public static void reverseString(String str) {
        reverseString(0, str);  // 内部调用带索引的版本
    }

    private static void reverseString(int n , String str){
        if(n == str.length()){
            return;
        }
        reverseString(n + 1 , str);
        System.out.println(str.charAt(n));
        /*
        时间轴 →
        --------------------------------------------------------------------------------
        递归调用栈：

        reverseString(0, "yulus")
            ├─ 等待打印
            │   reverseString(1, "yulus")
            │       ├─ 等待打印
            │       │   reverseString(2, "yulus")
            │       │       ├─ 等待打印
            │       │       │   reverseString(3, "yulus")
